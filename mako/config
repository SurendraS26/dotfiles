# Global Settings
max-visible=1
sort=-time
layer=overlay
anchor=top-right

# Geometry & Layout (Hyprland Gaps Style)
width=300
height=110
margin=20
padding=15
text-alignment=left

# Aesthetics (Matches Hyprland Active/Inactive Border Colors)
font=Monospace 10
background-color=#000000
text-color=#ffffff
border-size=1
border-color=#33ccffee
border-radius=0

# Functional Settings
icons=1
max-icon-size=32
default-timeout=5000
ignore-timeout=0

# Critical Alerts (Urgent Style)
[urgency=high]
border-color=#f38ba8ff
text-color=#f38ba8ff
default-timeout=0

