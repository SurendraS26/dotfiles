# Global Settings
max-visible=10
sort=-time
layer=overlay
anchor=bottom-right

# Geometry & Layout (Hyprland Gaps Style)
width=300
height=110
margin=0
padding=15
text-alignment=left

# Aesthetics (Matches Hyprland Active/Inactive Border Colors)
font=Monospace 10
background-color=#000000
text-color=#ffffff
border-size=2
border-color=#9400D3
border-radius=10

# Functional Settings
icons=1
max-icon-size=32
default-timeout=1500
ignore-timeout=0

# Critical Alerts (Urgent Style)
[urgency=high]
border-color=#f38ba8ff
text-color=#f38ba8ff
default-timeout=0

